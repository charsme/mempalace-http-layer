# Public hostname routed by Traefik
DOMAIN=mempalace.chars.me

# PyPI version to install. WARNING: "latest" picks up whatever is current at
# build time — if the image cache is cleared and you rebuild, you may get a
# newer (possibly breaking) version. Pin to a specific version for production.
# Find the latest release: https://pypi.org/project/mempalace/
MEMPALACE_VERSION=latest

# Internal port for mcp-proxy (must match Traefik label)
MCP_PORT=3000

# OAuth 2.0 credentials — used by all MCP clients
# OAUTH_CLIENT_ID:     the "username" you give to claude.ai and Claude Code
# OAUTH_CLIENT_SECRET: the "password" — generate with: openssl rand -hex 32
# OAUTH_STATIC_TOKEN:  optional persistent bearer token (survives restarts)
#                      generate with: openssl rand -hex 32
OAUTH_CLIENT_ID=mempalace
OAUTH_CLIENT_SECRET=replace-with-openssl-rand-hex-32
OAUTH_STATIC_TOKEN=
